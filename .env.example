OPENAI_API_KEY=your_openai_api_key
TOPAZ_API_KEY=your_topaz_api_key

SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_STORAGE_BUCKET=360-renders

# Required for beta auth. Only the first 5 comma-separated emails can log in, sign up, or recover password.
BETA_ALLOWED_EMAILS=email1@example.com,email2@example.com,email3@example.com,email4@example.com,email5@example.com

# Use real on Vercel beta. Omit this or set mock for local UI development.
RENDER_PROVIDER_MODE=real
